#!/usr/bin/with-contenv bashio
# ==============================================================================
# Home Assistant Add-on: HAY CM5 Fan Controller
# Thermal monitoring daemon with hysteresis-based fan control
# Uses libgpiod (/dev/gpiochip0) + MQTT discovery for proper HA entities
# ==============================================================================

bashio::log.info "Starting HAY CM5 Fan Controller daemon..."

# ==============================================================================
# Configuration
# ==============================================================================
GPIO_CHIP=$(bashio::config 'gpio_chip')
GPIO_LINE=$(bashio::config 'gpio_line')
POLL_INTERVAL=$(bashio::config 'poll_interval')
TEMP_ON=$(bashio::config 'temp_on')
TEMP_OFF=$(bashio::config 'temp_off')
FAN_MODE=$(bashio::config 'fan_mode')
TEMP_SENSOR=$(bashio::config 'temp_sensor_path')
ADDON_HOSTNAME=$(hostname)
ADDON_VERSION=$(bashio::addon.version)

# State tracking
FAN_STATE=""
GPIOSET_PID=""
LAST_REPORTED_STATE=""
LAST_REPORTED_CPU_TEMP=""
LAST_REPORTED_FREQ=""
LAST_REPORTED_THROTTLE=""
LAST_REPORTED_UNDERVOLT=""
SENSOR_CACHE_DIR="/tmp/hay_cm5_fan_cache"
mkdir -p "${SENSOR_CACHE_DIR}"

# CPU frequency + utilization tracking
CPUFREQ_DIR="/sys/devices/system/cpu/cpu0/cpufreq"
CPU_MAX_FREQ_KHZ=""
UNDERVOLT_PATH="/sys/class/hwmon/hwmon3/in0_lcrit_alarm"
THROTTLE_UTIL_THRESHOLD=80  # Consider CPU "busy" above this % utilization
PREV_CPU_IDLE=0
PREV_CPU_TOTAL=0
CPU_UTIL_PCT=0
LAST_REPORTED_UTIL=""

# ==============================================================================
# MQTT Setup â€” auto-detect via Supervisor API
# ==============================================================================
MQTT_AVAILABLE=false
MQTT_HOST=""
MQTT_PORT=""
MQTT_USER=""
MQTT_PASS=""

setup_mqtt() {
    bashio::log.info "Checking for MQTT service..."
    local mqtt_info
    mqtt_info=$(curl -s -H "Authorization: Bearer ${SUPERVISOR_TOKEN}" \
        http://supervisor/services/mqtt 2>/dev/null) || return

    local result
    result=$(echo "${mqtt_info}" | jq -r '.result' 2>/dev/null) || return

    if [ "${result}" = "ok" ]; then
        MQTT_HOST=$(echo "${mqtt_info}" | jq -r '.data.host')
        MQTT_PORT=$(echo "${mqtt_info}" | jq -r '.data.port')
        MQTT_USER=$(echo "${mqtt_info}" | jq -r '.data.username')
        MQTT_PASS=$(echo "${mqtt_info}" | jq -r '.data.password')

        # Test connection
        if mosquitto_pub -h "${MQTT_HOST}" -p "${MQTT_PORT}" \
            -u "${MQTT_USER}" -P "${MQTT_PASS}" \
            -t "hay_cm5_fan/status" -m "online" 2>/dev/null; then
            MQTT_AVAILABLE=true
            bashio::log.info "MQTT connected: ${MQTT_HOST}:${MQTT_PORT}"
            bashio::log.info "Entities will use MQTT discovery (unique IDs enabled)"
        else
            bashio::log.warning "MQTT credentials found but connection failed"
        fi
    else
        bashio::log.info "MQTT not available â€” using REST API (entities won't have unique IDs)"
    fi
}

mqtt_pub() {
    local topic=$1
    local payload=$2
    local retain_flag=""
    [ "${3}" = "retain" ] && retain_flag="-r"
    mosquitto_pub -h "${MQTT_HOST}" -p "${MQTT_PORT}" \
        -u "${MQTT_USER}" -P "${MQTT_PASS}" \
        -t "${topic}" -m "${payload}" ${retain_flag} 2>/dev/null
}

# ==============================================================================
# MQTT Discovery â€” register entities with HA (unique_id, device grouping)
# ==============================================================================
DEVICE_JSON="{\"identifiers\":[\"hay_cm5_fan_${ADDON_HOSTNAME}\"],\"name\":\"HAY CM5 Fan Controller\",\"model\":\"Raspberry Pi CM5 on HA Yellow\",\"manufacturer\":\"ShobuPrime\",\"sw_version\":\"${ADDON_VERSION}\"}"

publish_sensor_discovery() {
    local object_id=$1
    local name=$2
    local icon=${3:-"mdi:thermometer"}
    local unit=${4:-"\u00b0C"}
    local device_class=${5:-"temperature"}

    local payload
    payload=$(jq -cn \
        --arg name "$name" \
        --arg uid "hay_cm5_fan_${object_id}" \
        --arg oid "hay_cm5_${object_id}" \
        --arg st "hay_cm5_fan/${object_id}/state" \
        --arg at "hay_cm5_fan/${object_id}/attributes" \
        --arg unit "$unit" \
        --arg icon "$icon" \
        --arg dc "$device_class" \
        --argjson dev "$DEVICE_JSON" \
        '{
            name: $name,
            unique_id: $uid,
            object_id: $oid,
            state_topic: $st,
            json_attributes_topic: $at,
            unit_of_measurement: $unit,
            device_class: $dc,
            state_class: "measurement",
            icon: $icon,
            device: $dev
        }')

    mqtt_pub "homeassistant/sensor/hay_cm5_fan/${object_id}/config" "$payload" retain
}

publish_binary_sensor_discovery() {
    local object_id=$1
    local name=$2
    local icon=$3
    local dc=${4:-"running"}

    local payload
    payload=$(jq -cn \
        --arg name "$name" \
        --arg uid "hay_cm5_fan_${object_id}" \
        --arg oid "hay_cm5_${object_id}" \
        --arg st "hay_cm5_fan/${object_id}/state" \
        --arg at "hay_cm5_fan/${object_id}/attributes" \
        --arg icon "$icon" \
        --arg dc "$dc" \
        --argjson dev "$DEVICE_JSON" \
        '{
            name: $name,
            unique_id: $uid,
            object_id: $oid,
            state_topic: $st,
            json_attributes_topic: $at,
            device_class: $dc,
            payload_on: "ON",
            payload_off: "OFF",
            icon: $icon,
            device: $dev
        }')

    mqtt_pub "homeassistant/binary_sensor/hay_cm5_fan/${object_id}/config" "$payload" retain
}

publish_text_sensor_discovery() {
    local object_id=$1
    local name=$2
    local icon=$3

    local payload
    payload=$(jq -cn \
        --arg name "$name" \
        --arg uid "hay_cm5_fan_${object_id}" \
        --arg oid "hay_cm5_${object_id}" \
        --arg st "hay_cm5_fan/${object_id}/state" \
        --arg at "hay_cm5_fan/${object_id}/attributes" \
        --arg icon "$icon" \
        --argjson dev "$DEVICE_JSON" \
        '{
            name: $name,
            unique_id: $uid,
            object_id: $oid,
            state_topic: $st,
            json_attributes_topic: $at,
            icon: $icon,
            device: $dev
        }')

    mqtt_pub "homeassistant/sensor/hay_cm5_fan/${object_id}/config" "$payload" retain
}

# ==============================================================================
# Entity Publishing â€” MQTT or REST API fallback
# ==============================================================================
publish_state() {
    local entity_type=$1   # sensor, binary_sensor
    local object_id=$2     # processor_temperature
    local state=$3         # 63.9 or ON/OFF
    local friendly_name=$4 # CM5 Processor Temperature
    local attrs_json=$5    # JSON string of attributes

    if [ "${MQTT_AVAILABLE}" = "true" ]; then
        mqtt_pub "hay_cm5_fan/${object_id}/state" "${state}"
        [ -n "${attrs_json}" ] && \
            mqtt_pub "hay_cm5_fan/${object_id}/attributes" "${attrs_json}"
    else
        # REST API fallback â€” must include all attributes in every POST
        local full_attrs
        if [ -n "${attrs_json}" ]; then
            full_attrs=$(echo "${attrs_json}" | jq -c --arg fn "${friendly_name}" '. + {friendly_name: $fn}')
        else
            full_attrs="{\"friendly_name\": \"${friendly_name}\"}"
        fi

        curl -s -X POST \
            -H "Authorization: Bearer ${SUPERVISOR_TOKEN}" \
            -H "Content-Type: application/json" \
            -d "{\"state\": \"${state}\", \"attributes\": ${full_attrs}}" \
            "http://supervisor/core/api/states/${entity_type}.hay_cm5_${object_id}" > /dev/null 2>&1
    fi
}

# ==============================================================================
# GPIO Management
# ==============================================================================
kill_gpioset() {
    if [ -n "${GPIOSET_PID}" ] && kill -0 "${GPIOSET_PID}" 2>/dev/null; then
        kill "${GPIOSET_PID}" 2>/dev/null
        wait "${GPIOSET_PID}" 2>/dev/null
    fi
    GPIOSET_PID=""
}

set_fan() {
    local new_state=$1
    if [ "${new_state}" != "${FAN_STATE}" ]; then
        kill_gpioset
        # Retry up to 3 times if line is busy (previous container's gpioset may linger)
        local attempt=0
        while [ ${attempt} -lt 3 ]; do
            gpioset -c "${GPIO_CHIP}" -C "hay_cm5_fan" "${GPIO_LINE}=${new_state}" &
            GPIOSET_PID=$!
            sleep 0.3
            if kill -0 "${GPIOSET_PID}" 2>/dev/null; then
                break  # gpioset is running, line acquired
            fi
            attempt=$((attempt + 1))
            [ ${attempt} -lt 3 ] && bashio::log.warning "GPIO line busy, retry ${attempt}/3..." && sleep 2
        done
        FAN_STATE=${new_state}
        if [ "${new_state}" = "1" ]; then
            bashio::log.info "Fan turned ON (gpioset PID: ${GPIOSET_PID})"
        else
            bashio::log.info "Fan turned OFF (gpioset PID: ${GPIOSET_PID})"
        fi
    fi
}

cleanup() {
    bashio::log.info "Shutdown signal received..."
    kill_gpioset

    if bashio::config.true 'leave_on_at_shutdown'; then
        bashio::log.info "Leaving fan ON for safety"
        gpioset -c "${GPIO_CHIP}" -C "hay_cm5_fan" "${GPIO_LINE}=1" &
        sleep 0.2
    else
        bashio::log.info "Turning fan OFF"
        gpioset -c "${GPIO_CHIP}" -C "hay_cm5_fan" "${GPIO_LINE}=0" &
        sleep 0.2
    fi

    # Publish offline status via MQTT
    if [ "${MQTT_AVAILABLE}" = "true" ]; then
        mqtt_pub "hay_cm5_fan/status" "offline" retain
    fi

    rm -rf "${SENSOR_CACHE_DIR}" 2>/dev/null
    exit 0
}

trap cleanup SIGTERM SIGINT

# ==============================================================================
# GPIO Header + Temperature Status Report
# ==============================================================================
# Yellow 10-Pin Header (J11) physical pinout:
#   Odd pins (left)            Even pins (right)
#   Pin 1  3.3V Power          Pin 2  5V Power
#   Pin 3  GPIO2  I2C SDA      Pin 4  5V Power
#   Pin 5  GPIO3  I2C SCL      Pin 6  GND
#   Pin 7  GPIO4  GPCLK0       Pin 8  GPIO14 UART TX (fan)
#   Pin 9  GND                 Pin 10 GPIO15 UART RX

# Helper: parse a single GPIO line from gpioinfo output
# Sets: _GPIO_DIR, _GPIO_CONSUMER, _GPIO_STATUS
parse_gpio_line() {
    local gpio_num=$1
    _GPIO_DIR="input" ; _GPIO_CONSUMER="" ; _GPIO_STATUS=""

    echo "${_GPIOINFO}" > /tmp/hay_gpio_parse.tmp
    local line_info
    line_info=$(grep "line *${gpio_num}:" /tmp/hay_gpio_parse.tmp | head -1 || true)
    rm -f /tmp/hay_gpio_parse.tmp
    [ -z "${line_info}" ] && return

    echo "${line_info}" | grep -q "output" && _GPIO_DIR="output"
    if echo "${line_info}" | grep -q 'consumer=' 2>/dev/null; then
        _GPIO_CONSUMER=$(echo "${line_info}" | sed 's/.*consumer="\([^"]*\)".*/\1/' || true)
    fi

    if [ -n "${_GPIO_CONSUMER}" ]; then
        _GPIO_STATUS="[${_GPIO_DIR}, ${_GPIO_CONSUMER}]"
    else
        _GPIO_STATUS="[${_GPIO_DIR}]"
    fi
}

# â”€â”€ Table rendering primitives â”€â”€
# Simulates rendered table output with ASCII borders and dynamically
# centered content. Column widths are re-computed on every render so
# alignment stays perfect regardless of content length changes.

# Return the max string length among all arguments
max_len() {
    local max=0
    for s in "$@"; do [ ${#s} -gt ${max} ] && max=${#s}; done
    echo ${max}
}

# Center text within a field of given width
center_text() {
    local text=$1 width=$2
    local len=${#text}
    if [ ${len} -ge ${width} ]; then
        printf "%s" "${text}"
        return
    fi
    local pad_left=$(( (width - len) / 2 ))
    local pad_right=$(( width - len - pad_left ))
    printf "%${pad_left}s%s%${pad_right}s" "" "${text}" ""
}

# Build a horizontal border: +------+------+
# Usage: tbl_border w1 w2 w3 ...
tbl_border() {
    local result="+" first=true
    for w in "$@"; do
        result="${result}$(printf '%*s' $((w + 2)) '' | tr ' ' '-')+"
    done
    echo "${result}"
}

# Build a data row with centered content: | val | val |
# Usage: tbl_row val1 w1 val2 w2 ...
tbl_row() {
    local result="|"
    while [ $# -ge 2 ]; do
        local text=$1 width=$2
        shift 2
        result="${result} $(center_text "${text}" ${width}) |"
    done
    echo "${result}"
}

# â”€â”€ Combined status report: GPIO pinout + thermal â”€â”€
print_status_report() {
    # â”€â”€ Capture GPIO info â”€â”€
    _GPIOINFO=$(gpioinfo 2>/dev/null || true)

    parse_gpio_line 2  ; local s2=${_GPIO_STATUS} c2=${_GPIO_CONSUMER}
    parse_gpio_line 3  ; local s3=${_GPIO_STATUS} c3=${_GPIO_CONSUMER}
    parse_gpio_line 4  ; local s4=${_GPIO_STATUS} c4=${_GPIO_CONSUMER}
    parse_gpio_line 14 ; local s14=${_GPIO_STATUS} c14=${_GPIO_CONSUMER}
    parse_gpio_line 15 ; local s15=${_GPIO_STATUS} c15=${_GPIO_CONSUMER}

    local active=0 avail=0
    for c in "${c2}" "${c3}" "${c4}" "${c14}" "${c15}"; do
        [ -n "${c}" ] && active=$((active + 1)) || avail=$((avail + 1))
    done

    # â”€â”€ GPIO table data â”€â”€
    # Columns: Status | Name | Function | Pin | Pin | Function | Name | Status
    local R1_LS="" R1_LN="3v3"    R1_LF="Power"   R1_LP="Pin 1"  R1_RP="Pin 2"  R1_RF="Power"   R1_RN="5v"     R1_RS=""
    local R2_LS="${s2}"  R2_LN="GPIO2"  R2_LF="I2C SDA"  R2_LP="Pin 3"  R2_RP="Pin 4"  R2_RF="Power"   R2_RN="5v"     R2_RS=""
    local R3_LS="${s3}"  R3_LN="GPIO3"  R3_LF="I2C SCL"  R3_LP="Pin 5"  R3_RP="Pin 6"  R3_RF="Ground"  R3_RN="GND"    R3_RS=""
    local R4_LS="${s4}"  R4_LN="GPIO4"  R4_LF="GPCLK0"   R4_LP="Pin 7"  R4_RP="Pin 8"  R4_RF="UART TX" R4_RN="GPIO14" R4_RS="${s14}"
    local R5_LS="" R5_LN="GND"    R5_LF="Ground"  R5_LP="Pin 9"  R5_RP="Pin 10" R5_RF="UART RX" R5_RN="GPIO15" R5_RS="${s15}"

    # â”€â”€ Compute column widths (resilient: always re-measured from data) â”€â”€
    local W_LS=$(max_len "Status" "$R1_LS" "$R2_LS" "$R3_LS" "$R4_LS" "$R5_LS")
    local W_LN=$(max_len "Name" "$R1_LN" "$R2_LN" "$R3_LN" "$R4_LN" "$R5_LN")
    local W_LF=$(max_len "Function" "$R1_LF" "$R2_LF" "$R3_LF" "$R4_LF" "$R5_LF")
    local W_LP=$(max_len "Pin" "$R1_LP" "$R2_LP" "$R3_LP" "$R4_LP" "$R5_LP")
    local W_RP=$(max_len "Pin" "$R1_RP" "$R2_RP" "$R3_RP" "$R4_RP" "$R5_RP")
    local W_RF=$(max_len "Function" "$R1_RF" "$R2_RF" "$R3_RF" "$R4_RF" "$R5_RF")
    local W_RN=$(max_len "Name" "$R1_RN" "$R2_RN" "$R3_RN" "$R4_RN" "$R5_RN")
    local W_RS=$(max_len "Status" "$R1_RS" "$R2_RS" "$R3_RS" "$R4_RS" "$R5_RS")

    # â”€â”€ Render GPIO table â”€â”€
    bashio::log.info ""
    bashio::log.info "  Yellow 10-Pin GPIO Header (J11) -- Pin 1 = square pad"
    bashio::log.info ""
    bashio::log.info "$(tbl_border $W_LS $W_LN $W_LF $W_LP $W_RP $W_RF $W_RN $W_RS)"
    bashio::log.info "$(tbl_row "Status" $W_LS "Name" $W_LN "Function" $W_LF "Pin" $W_LP "Pin" $W_RP "Function" $W_RF "Name" $W_RN "Status" $W_RS)"
    bashio::log.info "$(tbl_border $W_LS $W_LN $W_LF $W_LP $W_RP $W_RF $W_RN $W_RS)"
    bashio::log.info "$(tbl_row "$R1_LS" $W_LS "$R1_LN" $W_LN "$R1_LF" $W_LF "$R1_LP" $W_LP "$R1_RP" $W_RP "$R1_RF" $W_RF "$R1_RN" $W_RN "$R1_RS" $W_RS)"
    bashio::log.info "$(tbl_row "$R2_LS" $W_LS "$R2_LN" $W_LN "$R2_LF" $W_LF "$R2_LP" $W_LP "$R2_RP" $W_RP "$R2_RF" $W_RF "$R2_RN" $W_RN "$R2_RS" $W_RS)"
    bashio::log.info "$(tbl_row "$R3_LS" $W_LS "$R3_LN" $W_LN "$R3_LF" $W_LF "$R3_LP" $W_LP "$R3_RP" $W_RP "$R3_RF" $W_RF "$R3_RN" $W_RN "$R3_RS" $W_RS)"
    bashio::log.info "$(tbl_row "$R4_LS" $W_LS "$R4_LN" $W_LN "$R4_LF" $W_LF "$R4_LP" $W_LP "$R4_RP" $W_RP "$R4_RF" $W_RF "$R4_RN" $W_RN "$R4_RS" $W_RS)"
    bashio::log.info "$(tbl_row "$R5_LS" $W_LS "$R5_LN" $W_LN "$R5_LF" $W_LF "$R5_LP" $W_LP "$R5_RP" $W_RP "$R5_RF" $W_RF "$R5_RN" $W_RN "$R5_RS" $W_RS)"
    bashio::log.info "$(tbl_border $W_LS $W_LN $W_LF $W_LP $W_RP $W_RF $W_RN $W_RS)"
    bashio::log.info "  ${active} active, ${avail} available"

    # â”€â”€ Read all temperatures â”€â”€
    local cpu_temp="" nvme_temp="" rp1_temp=""
    for hwmon_dir in /sys/class/hwmon/hwmon*; do
        [ -d "${hwmon_dir}" ] || continue
        local hname
        hname=$(cat "${hwmon_dir}/name" 2>/dev/null || true)
        for tf in "${hwmon_dir}"/temp*_input; do
            [ -f "${tf}" ] || continue
            local raw
            raw=$(cat "${tf}" 2>/dev/null || true)
            [ -z "${raw}" ] && continue
            local tc=$(( raw / 1000 )) tf2=$(( (raw % 1000) / 100 ))
            local tval="${tc}.${tf2}"
            case "${hname}" in
                cpu_thermal) cpu_temp="${tval}" ;;
                nvme)        nvme_temp="${tval}" ;;
                rp1_adc)     rp1_temp="${tval}" ;;
            esac
        done
    done

    # â”€â”€ System status table â”€â”€
    local fan_str="OFF"
    [ "${FAN_STATE}" = "1" ] && fan_str="ON"
    local fan_detail="${fan_str} (${FAN_MODE}, on>=${TEMP_ON}C off<=${TEMP_OFF}C)"

    # Read CPU stats for the report
    local rpt_freq="" rpt_max="" rpt_gov="" rpt_throttle="No" rpt_undervolt="OK" rpt_util="${CPU_UTIL_PCT}%"
    if [ -f "${CPUFREQ_DIR}/scaling_cur_freq" ]; then
        local fk
        fk=$(cat "${CPUFREQ_DIR}/scaling_cur_freq")
        rpt_freq="$((fk / 1000)) MHz"
        [ -n "${CPU_MAX_FREQ_KHZ}" ] && rpt_max="$((CPU_MAX_FREQ_KHZ / 1000)) MHz"
    fi
    [ -f "${CPUFREQ_DIR}/scaling_governor" ] && rpt_gov=$(cat "${CPUFREQ_DIR}/scaling_governor")
    if [ -f "${UNDERVOLT_PATH}" ]; then
        local uv
        uv=$(cat "${UNDERVOLT_PATH}" 2>/dev/null || echo "0")
        [ "${uv}" = "1" ] && rpt_undervolt="ALERT"
    fi
    # Throttle: high utilization + freq below max
    if [ -n "${rpt_freq}" ] && [ -n "${CPU_MAX_FREQ_KHZ}" ]; then
        local ck
        ck=$(cat "${CPUFREQ_DIR}/scaling_cur_freq" 2>/dev/null || echo "0")
        if [ "${ck}" -lt "${CPU_MAX_FREQ_KHZ}" ] && [ "${CPU_UTIL_PCT}" -ge "${THROTTLE_UTIL_THRESHOLD}" ]; then
            if [ "${rpt_undervolt}" = "ALERT" ]; then
                rpt_throttle="YES (undervoltage)"
            elif [ "${TEMP_C}" -ge 80 ]; then
                rpt_throttle="YES (thermal)"
            else
                rpt_throttle="YES (unknown)"
            fi
        fi
    fi

    local freq_display="${rpt_freq}"
    [ -n "${rpt_max}" ] && freq_display="${rpt_freq} / ${rpt_max}"

    local T_WN=$(max_len "Metric" "CM5 Processor" "CM5 I/O Controller (RP1)" "NVMe SSD" "CM5 Fan" "CPU Clock Speed" "CPU Utilization" "CPU Governor" "CPU Throttled" "Undervoltage")
    local T_WV=$(max_len "Value" "${cpu_temp}C" "${rp1_temp}C" "${nvme_temp}C" "${fan_detail}" "${freq_display}" "${rpt_util}" "${rpt_gov}" "${rpt_throttle}" "${rpt_undervolt}")

    bashio::log.info ""
    bashio::log.info "  System Status"
    bashio::log.info ""
    bashio::log.info "$(tbl_border $T_WN $T_WV)"
    bashio::log.info "$(tbl_row "Metric" $T_WN "Value" $T_WV)"
    bashio::log.info "$(tbl_border $T_WN $T_WV)"
    [ -n "${cpu_temp}" ]  && bashio::log.info "$(tbl_row "CM5 Processor" $T_WN "${cpu_temp}C" $T_WV)"
    [ -n "${rp1_temp}" ]  && bashio::log.info "$(tbl_row "CM5 I/O Controller (RP1)" $T_WN "${rp1_temp}C" $T_WV)"
    [ -n "${nvme_temp}" ] && bashio::log.info "$(tbl_row "NVMe SSD" $T_WN "${nvme_temp}C" $T_WV)"
    bashio::log.info "$(tbl_border $T_WN $T_WV)"
    bashio::log.info "$(tbl_row "CPU Clock Speed" $T_WN "${freq_display}" $T_WV)"
    bashio::log.info "$(tbl_row "CPU Utilization" $T_WN "${rpt_util}" $T_WV)"
    bashio::log.info "$(tbl_row "CPU Governor" $T_WN "${rpt_gov}" $T_WV)"
    bashio::log.info "$(tbl_row "CPU Throttled" $T_WN "${rpt_throttle}" $T_WV)"
    bashio::log.info "$(tbl_row "Undervoltage" $T_WN "${rpt_undervolt}" $T_WV)"
    bashio::log.info "$(tbl_border $T_WN $T_WV)"
    bashio::log.info "$(tbl_row "CM5 Fan" $T_WN "${fan_detail}" $T_WV)"
    bashio::log.info "$(tbl_border $T_WN $T_WV)"
    bashio::log.info ""

    # â”€â”€ Publish GPIO header HA entity â”€â”€
    local gpio_json
    gpio_json=$(jq -cn \
        --arg s2 "${s2}" --arg c2 "${c2:-none}" \
        --arg s3 "${s3}" --arg c3 "${c3:-none}" \
        --arg s4 "${s4}" --arg c4 "${c4:-none}" \
        --arg s14 "${s14}" --arg c14 "${c14:-none}" \
        --arg s15 "${s15}" --arg c15 "${c15:-none}" \
        '{
            pin_1: "3.3V Power", pin_2: "5V Power",
            pin_3_GPIO2: {function: "I2C SDA", status: $s2, consumer: $c2},
            pin_4: "5V Power",
            pin_5_GPIO3: {function: "I2C SCL", status: $s3, consumer: $c3},
            pin_6: "GND",
            pin_7_GPIO4: {function: "GPCLK0", status: $s4, consumer: $c4},
            pin_8_GPIO14: {function: "UART TX / Fan", status: $s14, consumer: $c14},
            pin_9: "GND",
            pin_10_GPIO15: {function: "UART RX", status: $s15, consumer: $c15}
        }' 2>/dev/null || echo '{}')

    publish_state "sensor" "gpio_header" "${active} active, ${avail} available" "CM5 GPIO Header" "${gpio_json}"
}

# ==============================================================================
# Sensor Discovery â€” map hwmon names to friendly English names
# ==============================================================================
get_friendly_name() {
    local hwmon_name=$1
    local sensor_label=$2

    case "${hwmon_name}" in
        cpu_thermal)
            echo "CM5 Processor Temperature"
            ;;
        rp1_adc)
            # RP1 is the I/O controller chip on the Pi 5 / CM5
            echo "CM5 I/O Controller Temperature"
            ;;
        nvme)
            if [ "${sensor_label}" = "Composite" ] || [ -z "${sensor_label}" ]; then
                echo "NVMe Temperature"
            else
                echo "NVMe ${sensor_label} Temperature"
            fi
            ;;
        *)
            if [ -n "${sensor_label}" ]; then
                echo "${hwmon_name} ${sensor_label} Temperature"
            else
                echo "${hwmon_name} Temperature"
            fi
            ;;
    esac
}

get_object_id() {
    local hwmon_name=$1
    local sensor_label=$2

    case "${hwmon_name}" in
        cpu_thermal)
            echo "processor_temperature"
            ;;
        rp1_adc)
            echo "io_controller_temperature"
            ;;
        nvme)
            if [ "${sensor_label}" = "Composite" ] || [ -z "${sensor_label}" ]; then
                echo "nvme_temperature"
            else
                local clean_label
                clean_label=$(echo "${sensor_label}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/_/g')
                echo "nvme_${clean_label}_temperature"
            fi
            ;;
        *)
            local clean_name
            clean_name=$(echo "${hwmon_name}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/_/g' | sed 's/__*/_/g')
            if [ -n "${sensor_label}" ]; then
                local clean_label
                clean_label=$(echo "${sensor_label}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/_/g' | sed 's/__*/_/g')
                echo "${clean_name}_${clean_label}_temperature"
            else
                echo "${clean_name}_temperature"
            fi
            ;;
    esac
}

discover_sensors() {
    bashio::log.info "Discovering hardware temperature sensors..."
    local sensor_count=0

    for hwmon_dir in /sys/class/hwmon/hwmon*; do
        [ -d "${hwmon_dir}" ] || continue

        local hwmon_name="unknown"
        [ -f "${hwmon_dir}/name" ] && hwmon_name=$(cat "${hwmon_dir}/name" 2>/dev/null || echo "unknown")

        for temp_file in "${hwmon_dir}"/temp*_input; do
            [ -f "${temp_file}" ] || continue

            local temp_idx
            temp_idx=$(basename "${temp_file}" | sed 's/temp\([0-9]*\)_input/\1/')

            local sensor_label=""
            local label_file="${hwmon_dir}/temp${temp_idx}_label"
            [ -f "${label_file}" ] && sensor_label=$(cat "${label_file}" 2>/dev/null || echo "")

            local friendly_name object_id
            friendly_name=$(get_friendly_name "${hwmon_name}" "${sensor_label}")
            object_id=$(get_object_id "${hwmon_name}" "${sensor_label}")

            # Primary CPU sensor handled separately but still needs discovery
            if [ "${temp_file}" = "${TEMP_SENSOR}" ]; then
                bashio::log.info "  [CPU] ${temp_file} -> ${friendly_name} (${object_id})"
                # Register MQTT discovery for CPU sensor
                if [ "${MQTT_AVAILABLE}" = "true" ]; then
                    publish_sensor_discovery "${object_id}" "${friendly_name}"
                fi
                # Store CPU object_id for the main loop
                echo "${object_id}|${friendly_name}" > "${SENSOR_CACHE_DIR}/_cpu_info"
                continue
            fi

            # Store sensor info
            local cache_key
            cache_key=$(echo "${temp_file}" | md5sum | cut -d' ' -f1)
            echo "${temp_file}|${object_id}|${friendly_name}" > "${SENSOR_CACHE_DIR}/${cache_key}"

            # Register MQTT discovery
            if [ "${MQTT_AVAILABLE}" = "true" ]; then
                publish_sensor_discovery "${object_id}" "${friendly_name}"
            fi

            sensor_count=$((sensor_count + 1))
            bashio::log.info "  [${sensor_count}] ${temp_file} -> ${friendly_name} (${object_id})"
        done
    done

    bashio::log.info "Discovered ${sensor_count} additional temperature sensor(s) beyond CPU"
}

# ==============================================================================
# Entity Updates
# ==============================================================================
update_primary_entities() {
    local temp_display=$1
    local fan_on=$2

    # Read CPU sensor info
    local cpu_info cpu_object_id cpu_friendly_name
    cpu_info=$(cat "${SENSOR_CACHE_DIR}/_cpu_info" 2>/dev/null || echo "processor_temperature|CM5 Processor Temperature")
    cpu_object_id=$(echo "${cpu_info}" | cut -d'|' -f1)
    cpu_friendly_name=$(echo "${cpu_info}" | cut -d'|' -f2)

    # CPU temperature (only when changed)
    if [ "${temp_display}" != "${LAST_REPORTED_CPU_TEMP}" ]; then
        local temp_attrs
        temp_attrs=$(jq -cn \
            --arg unit "Â°C" --arg src "${TEMP_SENSOR}" \
            '{unit_of_measurement: $unit, device_class: "temperature", state_class: "measurement", icon: "mdi:thermometer", source: $src}')
        publish_state "sensor" "${cpu_object_id}" "${temp_display}" "${cpu_friendly_name}" "${temp_attrs}"
        LAST_REPORTED_CPU_TEMP="${temp_display}"
    fi

    # Fan state (only when changed)
    local fan_state_str="OFF"
    [ "${fan_on}" = "1" ] && fan_state_str="ON"

    if [ "${fan_state_str}" != "${LAST_REPORTED_STATE}" ]; then
        local fan_attrs
        fan_attrs=$(jq -cn \
            --arg chip "${GPIO_CHIP}" --argjson line "${GPIO_LINE}" \
            --arg mode "${FAN_MODE}" --argjson temp_on "${TEMP_ON}" --argjson temp_off "${TEMP_OFF}" \
            --arg temp "${temp_display}" \
            '{icon: "mdi:fan", temperature: $temp, gpio_chip: $chip, gpio_line: $line, mode: $mode, temp_on_threshold: $temp_on, temp_off_threshold: $temp_off}')
        publish_state "binary_sensor" "fan" "${fan_state_str}" "CM5 Fan" "${fan_attrs}"
        LAST_REPORTED_STATE="${fan_state_str}"
    fi
}

update_discovered_sensors() {
    for cache_file in "${SENSOR_CACHE_DIR}"/*; do
        [ -f "${cache_file}" ] || continue
        # Skip internal files
        local basename_file
        basename_file=$(basename "${cache_file}")
        case "${basename_file}" in _*|*.last) continue ;; esac

        local line sensor_path object_id friendly_name
        line=$(cat "${cache_file}")
        sensor_path=$(echo "${line}" | cut -d'|' -f1)
        object_id=$(echo "${line}" | cut -d'|' -f2)
        friendly_name=$(echo "${line}" | cut -d'|' -f3)

        if [ -f "${sensor_path}" ]; then
            local raw_temp temp_c temp_frac temp_val
            raw_temp=$(cat "${sensor_path}" 2>/dev/null) || continue
            temp_c=$((raw_temp / 1000))
            temp_frac=$(( (raw_temp % 1000) / 100 ))
            temp_val="${temp_c}.${temp_frac}"

            local last_file="${cache_file}.last"
            local last_val=""
            [ -f "${last_file}" ] && last_val=$(cat "${last_file}")

            if [ "${temp_val}" != "${last_val}" ]; then
                local attrs
                attrs=$(jq -cn \
                    --arg unit "Â°C" --arg src "${sensor_path}" \
                    '{unit_of_measurement: $unit, device_class: "temperature", state_class: "measurement", icon: "mdi:thermometer", source: $src}')
                publish_state "sensor" "${object_id}" "${temp_val}" "${friendly_name}" "${attrs}"
                echo "${temp_val}" > "${last_file}"
            fi
        fi
    done
}

# ==============================================================================
# Validate & Start
# ==============================================================================
if [ "${TEMP_OFF}" -ge "${TEMP_ON}" ]; then
    if [ "${FAN_MODE}" = "auto" ]; then
        bashio::log.error "temp_off (${TEMP_OFF}) must be less than temp_on (${TEMP_ON})!"
        exit 1
    else
        bashio::log.warning "temp_off (${TEMP_OFF}) >= temp_on (${TEMP_ON}) â€” ignored (fan_mode=${FAN_MODE})"
    fi
fi

# Setup MQTT (optional)
setup_mqtt

# Register MQTT discovery entities
if [ "${MQTT_AVAILABLE}" = "true" ]; then
    bashio::log.info "Publishing MQTT discovery configs..."
    publish_binary_sensor_discovery "fan" "CM5 Fan" "mdi:fan"
    publish_sensor_discovery "cpu_clock_speed" "CM5 CPU Clock Speed" "mdi:speedometer" "MHz"
    publish_sensor_discovery "cpu_utilization" "CM5 CPU Utilization" "mdi:cpu-64-bit" "%"
    publish_binary_sensor_discovery "cpu_throttled" "CM5 CPU Throttled" "mdi:alert-octagon" "problem"
    publish_binary_sensor_discovery "undervoltage" "CM5 Undervoltage" "mdi:flash-alert" "problem"
    publish_text_sensor_discovery "cpu_governor" "CM5 CPU Governor" "mdi:tune"
    publish_text_sensor_discovery "gpio_header" "CM5 GPIO Header" "mdi:chip"
    # Temperature sensors are registered during discover_sensors()
fi

# Discover temperature sensors
discover_sensors

# Read CPU max frequency (static, doesn't change at runtime)
if [ -f "${CPUFREQ_DIR}/scaling_max_freq" ]; then
    CPU_MAX_FREQ_KHZ=$(cat "${CPUFREQ_DIR}/scaling_max_freq")
    bashio::log.info "CPU max frequency: $((CPU_MAX_FREQ_KHZ / 1000)) MHz"
fi

# Log configuration
bashio::log.info "Configuration:"
bashio::log.info "  GPIO: ${GPIO_CHIP} line ${GPIO_LINE}"
bashio::log.info "  Poll: ${POLL_INTERVAL}s | Thresholds: ON=${TEMP_ON}C OFF=${TEMP_OFF}C"
bashio::log.info "  Fan mode: ${FAN_MODE} | Leave on at shutdown: $(bashio::config 'leave_on_at_shutdown')"
bashio::log.info "  MQTT: ${MQTT_AVAILABLE} | Hostname: ${ADDON_HOSTNAME}"

# Initialize temperature variables (needed by status report before main loop)
TEMP_C=0
TEMP_DISPLAY="0.0"
if [ -f "${TEMP_SENSOR}" ]; then
    TEMP_RAW=$(cat "${TEMP_SENSOR}")
    TEMP_C=$((TEMP_RAW / 1000))
    TEMP_FRAC=$(( (TEMP_RAW % 1000) / 100 ))
    TEMP_DISPLAY="${TEMP_C}.${TEMP_FRAC}"
fi

# Turn fan ON as initial safe state (before first report so GPIO14 shows active)
bashio::log.info "Turning fan ON (initial safe state)..."
set_fan 1

# Print initial status report (GPIO + temps)
print_status_report

# ==============================================================================
# Main Loop
# ==============================================================================
GPIO_SCAN_COUNTER=0
GPIO_SCAN_INTERVAL=12  # Every 12 cycles (60s at 5s poll)

while true; do
    # Verify gpioset is still holding the line
    if [ -n "${GPIOSET_PID}" ] && ! kill -0 "${GPIOSET_PID}" 2>/dev/null; then
        bashio::log.warning "gpioset process died unexpectedly, restarting with fan ON..."
        FAN_STATE=""
        set_fan 1
    fi

    # Read CPU temperature
    if [ -f "${TEMP_SENSOR}" ]; then
        TEMP_RAW=$(cat "${TEMP_SENSOR}")
        TEMP_C=$((TEMP_RAW / 1000))
        TEMP_FRAC=$(( (TEMP_RAW % 1000) / 100 ))
        TEMP_DISPLAY="${TEMP_C}.${TEMP_FRAC}"
    else
        bashio::log.warning "CPU temp sensor not found: ${TEMP_SENSOR}"
        set_fan 1
        sleep "${POLL_INTERVAL}"
        continue
    fi

    # Apply fan control
    case "${FAN_MODE}" in
        on)  set_fan 1 ;;
        off) set_fan 0 ;;
        auto)
            if [ "${TEMP_C}" -ge "${TEMP_ON}" ]; then
                set_fan 1
            elif [ "${TEMP_C}" -le "${TEMP_OFF}" ]; then
                set_fan 0
            fi
            ;;
    esac

    # â”€â”€ CPU utilization (from /proc/stat delta between poll cycles) â”€â”€
    # /proc/stat cpu line: user nice system idle iowait irq softirq steal
    cpu_line=$(head -1 /proc/stat)
    cpu_user=$(echo "${cpu_line}" | awk '{print $2}')
    cpu_nice=$(echo "${cpu_line}" | awk '{print $3}')
    cpu_system=$(echo "${cpu_line}" | awk '{print $4}')
    cpu_idle=$(echo "${cpu_line}" | awk '{print $5}')
    cpu_iowait=$(echo "${cpu_line}" | awk '{print $6}')
    cpu_irq=$(echo "${cpu_line}" | awk '{print $7}')
    cpu_softirq=$(echo "${cpu_line}" | awk '{print $8}')
    cpu_steal=$(echo "${cpu_line}" | awk '{print $9}')

    cpu_total=$((cpu_user + cpu_nice + cpu_system + cpu_idle + cpu_iowait + cpu_irq + cpu_softirq + cpu_steal))

    if [ "${PREV_CPU_TOTAL}" -gt 0 ]; then
        delta_total=$((cpu_total - PREV_CPU_TOTAL))
        delta_idle=$((cpu_idle - PREV_CPU_IDLE))
        if [ "${delta_total}" -gt 0 ]; then
            CPU_UTIL_PCT=$(( (delta_total - delta_idle) * 100 / delta_total ))
        fi
    fi
    PREV_CPU_TOTAL=${cpu_total}
    PREV_CPU_IDLE=${cpu_idle}

    # â”€â”€ CPU clock speed + throttle detection â”€â”€
    CUR_FREQ_KHZ=""
    CUR_FREQ_MHZ=""
    CPU_THROTTLED="OFF"
    CPU_UNDERVOLT="OFF"
    CPU_GOVERNOR=""
    THROTTLE_REASON=""

    if [ -f "${CPUFREQ_DIR}/scaling_cur_freq" ]; then
        CUR_FREQ_KHZ=$(cat "${CPUFREQ_DIR}/scaling_cur_freq")
        CUR_FREQ_MHZ=$((CUR_FREQ_KHZ / 1000))
    fi
    if [ -f "${CPUFREQ_DIR}/scaling_governor" ]; then
        CPU_GOVERNOR=$(cat "${CPUFREQ_DIR}/scaling_governor")
    fi
    if [ -f "${UNDERVOLT_PATH}" ]; then
        uv_val=$(cat "${UNDERVOLT_PATH}" 2>/dev/null || echo "0")
        [ "${uv_val}" = "1" ] && CPU_UNDERVOLT="ON"
    fi

    # Throttle detection: CPU wants to run fast (high utilization) but
    # frequency is below max. This means something is capping it.
    #   - If temp is high: thermal throttle
    #   - If undervoltage: power throttle
    #   - If neither: unknown cap (firmware/kernel limit)
    # Low utilization + low freq = normal governor power saving (NOT throttle)
    if [ -n "${CUR_FREQ_KHZ}" ] && [ -n "${CPU_MAX_FREQ_KHZ}" ]; then
        if [ "${CUR_FREQ_KHZ}" -lt "${CPU_MAX_FREQ_KHZ}" ] && [ "${CPU_UTIL_PCT}" -ge "${THROTTLE_UTIL_THRESHOLD}" ]; then
            CPU_THROTTLED="ON"
            if [ "${CPU_UNDERVOLT}" = "ON" ]; then
                THROTTLE_REASON="undervoltage"
            elif [ "${TEMP_C}" -ge 80 ]; then
                THROTTLE_REASON="thermal"
            else
                THROTTLE_REASON="unknown"
            fi
        fi
    fi

    # Log throttle state changes with detailed context
    if [ "${CPU_THROTTLED}" != "${LAST_REPORTED_THROTTLE}" ]; then
        if [ "${CPU_THROTTLED}" = "ON" ]; then
            bashio::log.warning "CPU THROTTLED (${THROTTLE_REASON}): ${CUR_FREQ_MHZ}/${CPU_MAX_FREQ_KHZ:+$((CPU_MAX_FREQ_KHZ / 1000))} MHz, ${CPU_UTIL_PCT}% util, ${TEMP_DISPLAY}C"
        elif [ "${LAST_REPORTED_THROTTLE}" = "ON" ]; then
            bashio::log.info "CPU throttle cleared: ${CUR_FREQ_MHZ} MHz, ${CPU_UTIL_PCT}% util, ${TEMP_DISPLAY}C"
        fi
    fi
    if [ "${CPU_UNDERVOLT}" != "${LAST_REPORTED_UNDERVOLT}" ]; then
        if [ "${CPU_UNDERVOLT}" = "ON" ]; then
            bashio::log.warning "UNDERVOLTAGE DETECTED -- check power supply!"
        elif [ "${LAST_REPORTED_UNDERVOLT}" = "ON" ]; then
            bashio::log.info "Undervoltage cleared"
        fi
    fi

    # â”€â”€ Publish clock speed entity â”€â”€
    if [ -n "${CUR_FREQ_MHZ}" ] && [ "${CUR_FREQ_MHZ}" != "${LAST_REPORTED_FREQ}" ]; then
        freq_attrs=$(jq -cn \
            --arg unit "MHz" --argjson max "$((CPU_MAX_FREQ_KHZ / 1000))" --arg gov "${CPU_GOVERNOR}" \
            --argjson util "${CPU_UTIL_PCT}" \
            '{unit_of_measurement: $unit, icon: "mdi:speedometer", state_class: "measurement", max_frequency_mhz: $max, governor: $gov, cpu_utilization_pct: $util}')
        publish_state "sensor" "cpu_clock_speed" "${CUR_FREQ_MHZ}" "CM5 CPU Clock Speed" "${freq_attrs}"
        LAST_REPORTED_FREQ="${CUR_FREQ_MHZ}"
    fi

    # â”€â”€ Publish CPU utilization entity â”€â”€
    if [ "${CPU_UTIL_PCT}" != "${LAST_REPORTED_UTIL}" ]; then
        util_attrs=$(jq -cn --arg unit "%" '{unit_of_measurement: $unit, icon: "mdi:cpu-64-bit", state_class: "measurement"}')
        publish_state "sensor" "cpu_utilization" "${CPU_UTIL_PCT}" "CM5 CPU Utilization" "${util_attrs}"
        LAST_REPORTED_UTIL="${CPU_UTIL_PCT}"
    fi

    # â”€â”€ Publish throttle + undervoltage entities â”€â”€
    if [ "${CPU_THROTTLED}" != "${LAST_REPORTED_THROTTLE}" ]; then
        thr_attrs=$(jq -cn \
            --arg freq "${CUR_FREQ_MHZ} MHz" --arg max "$((CPU_MAX_FREQ_KHZ / 1000)) MHz" \
            --arg temp "${TEMP_DISPLAY}C" --argjson util "${CPU_UTIL_PCT}" \
            --arg reason "${THROTTLE_REASON}" \
            '{icon: "mdi:alert-octagon", frequency: $freq, max_frequency: $max, temperature: $temp, cpu_utilization_pct: $util, reason: $reason}')
        publish_state "binary_sensor" "cpu_throttled" "${CPU_THROTTLED}" "CM5 CPU Throttled" "${thr_attrs}"
        LAST_REPORTED_THROTTLE="${CPU_THROTTLED}"
    fi
    if [ "${CPU_UNDERVOLT}" != "${LAST_REPORTED_UNDERVOLT}" ]; then
        uv_attrs='{"icon": "mdi:flash-alert"}'
        publish_state "binary_sensor" "undervoltage" "${CPU_UNDERVOLT}" "CM5 Undervoltage" "${uv_attrs}"
        LAST_REPORTED_UNDERVOLT="${CPU_UNDERVOLT}"
    fi

    # â”€â”€ Publish governor (rarely changes, check each cycle) â”€â”€
    if [ -n "${CPU_GOVERNOR}" ]; then
        publish_state "sensor" "cpu_governor" "${CPU_GOVERNOR}" "CM5 CPU Governor" '{"icon": "mdi:tune"}'
    fi

    # Update temperature + fan entities
    update_primary_entities "${TEMP_DISPLAY}" "${FAN_STATE}"
    update_discovered_sensors

    # Periodic status report (GPIO + temps)
    GPIO_SCAN_COUNTER=$((GPIO_SCAN_COUNTER + 1))
    if [ "${GPIO_SCAN_COUNTER}" -ge "${GPIO_SCAN_INTERVAL}" ]; then
        print_status_report
        GPIO_SCAN_COUNTER=0
    fi

    sleep "${POLL_INTERVAL}"
done
